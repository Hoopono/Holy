<script>
/* PARTÍCULAS */
const canvas=document.getElementById('particles'),ctx=canvas.getContext('2d');
let W,H,particles=[];
function resize(){W=canvas.width=innerWidth;H=canvas.height=innerHeight}
resize();window.addEventListener('resize',resize);
function rp(){return{x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*.4,vy:(Math.random()-.5)*.4,r:Math.random()*2+.5,alpha:Math.random()*.5+.1,color:Math.random()>.5?'124,58,237':'6,182,212'}}
for(let i=0;i<90;i++)particles.push(rp());
function draw(){ctx.clearRect(0,0,W,H);particles.forEach(p=>{p.x+=p.vx;p.y+=p.vy;if(p.x<0)p.x=W;if(p.x>W)p.x=0;if(p.y<0)p.y=H;if(p.y>H)p.y=0;ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fillStyle=`rgba(${p.color},${p.alpha})`;ctx.fill()});for(let i=0;i<particles.length;i++)for(let j=i+1;j<particles.length;j++){const dx=particles[i].x-particles[j].x,dy=particles[i].y-particles[j].y,d=Math.sqrt(dx*dx+dy*dy);if(d<120){ctx.beginPath();ctx.strokeStyle=`rgba(124,58,237,${.15*(1-d/120)})`;ctx.lineWidth=.5;ctx.moveTo(particles[i].x,particles[i].y);ctx.lineTo(particles[j].x,particles[j].y);ctx.stroke()}}requestAnimationFrame(draw)}
draw();

/* COUNTDOWN */
const endTime=new Date(Date.now()+2*60*60*1000+34*60*1000);
function updateCountdown(){const now=new Date(),diff=endTime-now;if(diff<=0)return;const h=Math.floor(diff/3600000),m=Math.floor((diff%3600000)/60000),s=Math.floor((diff%60000)/1000);document.getElementById('cb-h').textContent=String(h).padStart(2,'0');document.getElementById('cb-m').textContent=String(m).padStart(2,'0');document.getElementById('cb-s').textContent=String(s).padStart(2,'0')}
updateCountdown();setInterval(updateCountdown,1000);

/* TYPEWRITER */
const twWords=['Landing Pages','Sites Institucionais','Lojas Virtuais','Sistemas Web','SEO e Performance'];
let twI=0,twC=0,twDel=false;
function typewrite(){const word=twWords[twI];const el=document.getElementById('tw');if(!twDel){el.textContent=word.slice(0,++twC);if(twC===word.length){twDel=true;setTimeout(typewrite,1800);return}}else{el.textContent=word.slice(0,--twC);if(twC===0){twDel=false;twI=(twI+1)%twWords.length}}setTimeout(typewrite,twDel?60:90)}
setTimeout(typewrite,1500);

/* CONTADORES */
function animateCount(id,target,suffix=''){const el=document.getElementById(id);let start=0;const step=ts=>{if(!start)start=ts;const p=Math.min((ts-start)/1800,1);el.textContent=Math.floor(p*target)+suffix;if(p<1)requestAnimationFrame(step)};requestAnimationFrame(step)}
setTimeout(()=>{animateCount('cnt1',120,'+');animateCount('cnt2',98,'+');animateCount('cnt3',5,'+')},600);

/* SCROLL REVEAL */
const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible')})},{threshold:.12});
document.querySelectorAll('.card,.step,.dep-card,.mockup-wrap,.cta-box,.faq-item').forEach(el=>obs.observe(el));

/* THEME */
let dark=true;
function toggleTheme(){dark=!dark;document.body.classList.toggle('light',!dark);document.getElementById('themeBtn').textContent=dark?'🌙':'☀️'}

/* CALC */
let planPrice=1297,addonTotal=0;
function selectPlan(el,price){document.querySelectorAll('.calc-option').forEach(o=>{o.classList.remove('selected')});el.classList.add('selected');planPrice=price;updateTotal()}
function toggleAddon(el,price){if(el.classList.contains('selected')){el.classList.remove('selected');addonTotal-=price}else{el.classList.add('selected');addonTotal+=price}updateTotal()}
function updateTotal(){const t=planPrice+addonTotal;document.getElementById('calcTotal').textContent='R$ '+t.toLocaleString('pt-BR')}

/* FAQ */
function toggleFaq(el){const item=el.parentElement;const isOpen=item.classList.contains('open');document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));if(!isOpen)item.classList.add('open')}

/* CHAT */
let chatOpen=false;
function toggleChat(){chatOpen=!chatOpen;document.getElementById('chatPopup').classList.toggle('open',chatOpen);document.getElementById('notif').style.display=chatOpen?'none':'flex'}
const responses=['Ótimo! Pode me contar mais sobre seu negócio? 😊','Perfeito! Me passa seu WhatsApp e te envio um orçamento 📱','Claro! Faço uma proposta sem compromisso em até 24h ⚡','Show! Qual é o prazo que você tem em mente? 🚀'];
let ri=0;
function sendMsg(){const inp=document.getElementById('chatInput'),txt=inp.value.trim();if(!txt)return;const body=document.getElementById('chatBody');const um=document.createElement('div');um.className='msg user';um.textContent=txt;body.appendChild(um);inp.value='';const typing=document.createElement('div');typing.className='msg bot typing-dots';typing.innerHTML='<span></span><span></span><span></span>';body.appendChild(typing);body.scrollTop=body.scrollHeight;setTimeout(()=>{body.removeChild(typing);const bm=document.createElement('div');bm.className='msg bot';bm.textContent=responses[ri%responses.length];ri++;body.appendChild(bm);body.scrollTop=body.scrollHeight},1200)}

/* EXIT POPUP */
let exitShown=false;
document.addEventListener('mouseleave',e=>{if(e.clientY<10&&!exitShown){exitShown=true;document.getElementById('exitOverlay').classList.add('open')}});
function closeExit(){document.getElementById('exitOverlay').classList.remove('open')}

/* MODAL */
const mdata={landing:{title:'🚀 Preview — Landing Page',tabs:['Hero / CTA','Benefícios','Depoimentos','Rodapé']},institucional:{title:'💼 Preview — Site Institucional',tabs:['Página inicial','Serviços','Sobre nós','Contato']},loja:{title:'🛒 Preview — Loja Virtual',tabs:['Home / Banner','Catálogo','Produto','Checkout']},sistema:{title:'⚙️ Preview — Sistema Web',tabs:['Dashboard','Clientes','Pedidos','Financeiro']}};
function openModal(type){document.getElementById('modalTitle').textContent=mdata[type].title;const tabs=document.getElementById('modalTabs');tabs.innerHTML='';mdata[type].tabs.forEach((l,i)=>{const b=document.createElement('button');b.className='tab-btn'+(i===0?' active':'');b.textContent=l;b.onclick=()=>switchTab(type,b);tabs.appendChild(b)});document.querySelectorAll('.preview-panel').forEach(p=>p.classList.remove('active'));document.getElementById('panel-'+type).classList.add('active');document.getElementById('modalOverlay').classList.add('open');document.body.style.overflow='hidden'}
function switchTab(type,btn){document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');const p=document.getElementById('panel-'+type);p.style.animation='none';p.offsetHeight;p.style.animation='fadeUp .4s ease both'}
function closeModal(){document.getElementById('modalOverlay').classList.remove('open');document.body.style.overflow=''}
function handleOverlayClick(e){if(e.target===document.getElementById('modalOverlay'))closeModal()}
document.addEventListener('keydown',e=>{if(e.key==='Escape'){closeModal();closeExit()}});
</script>
