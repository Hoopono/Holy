<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WebCraft Pro — Sites que Vendem</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap');
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#07070F;--bg2:#0D0D1A;--purple:#7C3AED;--purple-light:#A855F7;
  --cyan:#06B6D4;--green:#10B981;--white:#F8FAFC;--muted:#94A3B8;
  --card:rgba(255,255,255,0.04);--border:rgba(255,255,255,0.08);
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--white);font-family:'Space Grotesk',sans-serif;overflow-x:hidden}
body.light{--bg:#F0F4FF;--bg2:#E8EDFF;--white:#0C0C1A;--muted:#475569;--card:rgba(0,0,0,0.04);--border:rgba(0,0,0,0.1)}
body.light nav{background:rgba(240,244,255,0.85)}
body.light footer{background:var(--bg2)}
#particles{position:fixed;inset:0;z-index:0;pointer-events:none}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:1.2rem 6%;background:rgba(7,7,15,0.7);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);animation:slideDown .8s ease both}
.logo{font-family:'Syne',sans-serif;font-size:1.4rem;background:linear-gradient(90deg,var(--purple-light),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{color:var(--muted);text-decoration:none;font-size:.9rem;font-weight:500;transition:color .3s}
.nav-links a:hover{color:var(--white)}
.nav-right{display:flex;align-items:center;gap:.8rem}
.btn-nav{background:linear-gradient(135deg,var(--purple),var(--cyan));color:#fff;border:none;padding:.6rem 1.4rem;border-radius:50px;font-family:'Space Grotesk',sans-serif;font-weight:600;cursor:pointer;font-size:.9rem;transition:transform .2s,box-shadow .2s}
.btn-nav:hover{transform:scale(1.05);box-shadow:0 0 20px rgba(124,58,237,.5)}
.theme-toggle{background:var(--card);border:1px solid var(--border);color:var(--white);width:36px;height:36px;border-radius:50%;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;transition:all .3s}
.theme-toggle:hover{border-color:var(--purple-light)}

/* COUNTDOWN BANNER */
.countdown-banner{position:relative;z-index:99;background:linear-gradient(90deg,var(--purple),var(--cyan));padding:.7rem 6%;display:flex;align-items:center;justify-content:center;gap:1rem;flex-wrap:wrap;margin-top:65px}
.cb-text{font-size:.85rem;font-weight:600}
.cb-timer{display:flex;gap:.4rem;align-items:center}
.cb-unit{background:rgba(0,0,0,.25);border-radius:6px;padding:.2rem .5rem;font-family:'Syne',sans-serif;font-weight:800;font-size:1rem;min-width:36px;text-align:center}
.cb-sep{font-weight:800;opacity:.7}
.cb-badge{background:rgba(0,0,0,.2);border-radius:20px;padding:.2rem .7rem;font-size:.75rem;font-weight:700;letter-spacing:.04em}

/* HERO */
#hero{position:relative;z-index:1;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:4rem 6% 4rem}
.badge{display:inline-flex;align-items:center;gap:.5rem;background:rgba(124,58,237,.15);border:1px solid rgba(124,58,237,.4);color:var(--purple-light);padding:.4rem 1rem;border-radius:50px;font-size:.82rem;font-weight:600;letter-spacing:.04em;margin-bottom:2rem;animation:fadeUp .8s .3s ease both}
.badge .dot{width:7px;height:7px;border-radius:50%;background:var(--purple-light);animation:pulse 1.5s infinite}
h1{font-family:'Syne',sans-serif;font-size:clamp(2.8rem,7vw,5.5rem);line-height:1.05;max-width:820px;animation:fadeUp .9s .5s ease both}
h1 .gradient{background:linear-gradient(90deg,var(--purple-light),var(--cyan),var(--purple-light));background-size:200%;-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:shimmer 3s linear infinite}
.typewriter-wrap{font-size:1.3rem;font-weight:600;margin-top:.5rem;min-height:2rem;animation:fadeUp .9s .6s ease both}
.typewriter{color:var(--cyan)}
.cursor{display:inline-block;animation:blink .7s step-end infinite;color:var(--cyan)}
.subtitle{color:var(--muted);font-size:1.15rem;max-width:560px;margin:1.5rem auto 2.5rem;line-height:1.7;animation:fadeUp 1s .7s ease both}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;animation:fadeUp 1s .9s ease both}
.btn-primary{background:linear-gradient(135deg,var(--purple),var(--cyan));color:#fff;border:none;padding:.9rem 2.2rem;border-radius:50px;font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:1rem;cursor:pointer;position:relative;overflow:hidden;transition:transform .2s,box-shadow .3s;animation:glow 2s ease-in-out infinite alternate}
.btn-primary::after{content:'';position:absolute;inset:0;background:rgba(255,255,255,.2);transform:translateX(-100%) skewX(-20deg);transition:transform .5s}
.btn-primary:hover::after{transform:translateX(200%) skewX(-20deg)}
.btn-primary:hover{transform:scale(1.05)}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--white);padding:.9rem 2.2rem;border-radius:50px;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:1rem;cursor:pointer;transition:border-color .3s,background .3s}
.btn-outline:hover{border-color:var(--purple-light);background:rgba(124,58,237,.1)}
.hero-stats{display:flex;gap:3rem;margin-top:4rem;flex-wrap:wrap;justify-content:center;animation:fadeUp 1s 1.1s ease both}
.stat{text-align:center}
.stat-num{font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;background:linear-gradient(90deg,var(--purple-light),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.stat-label{color:var(--muted);font-size:.85rem;margin-top:.2rem}

/* GUARANTEE BADGES */
.guarantee-badges{display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;margin-top:2.5rem;animation:fadeUp 1s 1.2s ease both}
.g-badge{display:flex;align-items:center;gap:.4rem;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.3);color:#10B981;padding:.4rem .9rem;border-radius:20px;font-size:.75rem;font-weight:600}

/* LOGO CAROUSEL */
#clientes{position:relative;z-index:1;padding:2.5rem 0;background:linear-gradient(180deg,var(--bg) 0%,var(--bg2) 100%);border-top:1px solid var(--border);border-bottom:1px solid var(--border);overflow:hidden}
.carousel-label{text-align:center;font-size:.72rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:1.2rem}
.carousel-track-wrap{overflow:hidden;position:relative}
.carousel-track-wrap::before,.carousel-track-wrap::after{content:'';position:absolute;top:0;bottom:0;width:100px;z-index:2}
.carousel-track-wrap::before{left:0;background:linear-gradient(90deg,var(--bg2),transparent)}
.carousel-track-wrap::after{right:0;background:linear-gradient(-90deg,var(--bg2),transparent)}
.carousel-track{display:flex;gap:3rem;align-items:center;animation:carouselScroll 25s linear infinite;width:max-content}
.carousel-track:hover{animation-play-state:paused}
.logo-item{display:flex;align-items:center;gap:.5rem;background:var(--card);border:1px solid var(--border);border-radius:10px;padding:.6rem 1.2rem;white-space:nowrap;font-weight:700;font-size:.85rem;color:var(--muted);transition:color .3s,border-color .3s}
.logo-item:hover{color:var(--white);border-color:var(--purple)}
.logo-item span{font-size:1.2rem}

section{position:relative;z-index:1}
.section-label{font-size:.8rem;font-weight:700;letter-spacing:.12em;color:var(--purple-light);text-transform:uppercase;margin-bottom:.8rem}
.section-title{font-family:'Syne',sans-serif;font-size:clamp(1.9rem,4vw,3rem);line-height:1.15;margin-bottom:1rem}
.section-sub{color:var(--muted);font-size:1rem;line-height:1.7;max-width:560px}

/* SERVIÇOS */
#servicos{padding:6rem 6%;background:linear-gradient(180deg,var(--bg2) 0%,var(--bg) 100%)}
.services-header{text-align:center;margin-bottom:4rem}
.services-header .section-sub{margin:0 auto}
.cards-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem}
.card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:2rem;position:relative;overflow:hidden;cursor:pointer;opacity:0;transform:translateY(40px);transition:transform .4s cubic-bezier(.34,1.56,.64,1),border-color .3s,box-shadow .4s}
.card.visible{animation:cardIn .6s ease forwards}
.card::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 0%,rgba(124,58,237,.15),transparent 70%);opacity:0;transition:opacity .4s}
.card:hover{transform:translateY(-8px) scale(1.02);border-color:var(--purple);box-shadow:0 20px 60px rgba(124,58,237,.2)}
.card:hover::before{opacity:1}
.card-icon{width:54px;height:54px;border-radius:14px;background:linear-gradient(135deg,rgba(124,58,237,.3),rgba(6,182,212,.3));border:1px solid rgba(124,58,237,.4);display:flex;align-items:center;justify-content:center;font-size:1.6rem;margin-bottom:1.2rem}
.card h3{font-family:'Syne',sans-serif;font-size:1.2rem;margin-bottom:.6rem}
.card p{color:var(--muted);font-size:.9rem;line-height:1.6}
.card-price{margin-top:1.2rem;padding-top:1.2rem;border-top:1px solid var(--border);font-weight:700;font-size:1.4rem}
.card-price span{font-size:.85rem;color:var(--muted);font-weight:400}
.tag{position:absolute;top:1rem;right:1rem;background:linear-gradient(135deg,var(--purple),var(--cyan));font-size:.7rem;font-weight:700;padding:.25rem .6rem;border-radius:20px;letter-spacing:.06em}
.card-preview-hint{margin-top:1rem;display:flex;align-items:center;gap:.4rem;color:var(--cyan);font-size:.8rem;font-weight:600;opacity:0;transform:translateY(6px);transition:all .3s}
.card:hover .card-preview-hint{opacity:1;transform:none}

/* CALCULADORA */
#calculadora{padding:6rem 6%;background:linear-gradient(180deg,var(--bg) 0%,var(--bg2) 100%)}
.calc-header{text-align:center;margin-bottom:3rem}
.calc-box{max-width:720px;margin:0 auto;background:var(--card);border:1px solid var(--border);border-radius:24px;padding:2.5rem}
.calc-section-title{font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--purple-light);margin-bottom:1rem}
.calc-options{display:flex;flex-direction:column;gap:.6rem;margin-bottom:2rem}
.calc-option{display:flex;align-items:center;justify-content:space-between;padding:.9rem 1.2rem;background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:12px;cursor:pointer;transition:border-color .25s,background .25s;user-select:none}
.calc-option:hover{border-color:var(--purple);background:rgba(124,58,237,.06)}
.calc-option.selected{border-color:var(--purple);background:rgba(124,58,237,.12)}
.calc-option-left{display:flex;align-items:center;gap:.8rem}
.calc-option-icon{font-size:1.2rem}
.calc-option-name{font-weight:600;font-size:.9rem}
.calc-option-desc{color:var(--muted);font-size:.75rem}
.calc-option-price{font-weight:700;color:var(--cyan);font-size:.95rem}
.calc-check{width:20px;height:20px;border-radius:50%;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;transition:all .25s;flex-shrink:0}
.calc-option.selected .calc-check{background:var(--purple);border-color:var(--purple)}
.calc-option.selected .calc-check::after{content:'✓';font-size:.65rem;color:#fff}
.calc-divider{height:1px;background:var(--border);margin:1.5rem 0}
.addons-grid{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;margin-bottom:2rem}
.addon-option{display:flex;align-items:center;gap:.7rem;padding:.75rem 1rem;background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:10px;cursor:pointer;transition:all .25s;user-select:none}
.addon-option:hover{border-color:var(--cyan)}
.addon-option.selected{border-color:var(--cyan);background:rgba(6,182,212,.08)}
.addon-check{width:16px;height:16px;border-radius:4px;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;transition:all .25s;flex-shrink:0}
.addon-option.selected .addon-check{background:var(--cyan);border-color:var(--cyan)}
.addon-option.selected .addon-check::after{content:'✓';font-size:.55rem;color:#fff}
.addon-info{flex:1}
.addon-name{font-size:.82rem;font-weight:600}
.addon-price{font-size:.72rem;color:var(--cyan)}
.calc-total-box{background:linear-gradient(135deg,rgba(124,58,237,.2),rgba(6,182,212,.1));border:1px solid rgba(124,58,237,.4);border-radius:16px;padding:1.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem}
.calc-total-label{font-size:.85rem;color:var(--muted)}
.calc-total-val{font-family:'Syne',sans-serif;font-size:2.2rem;font-weight:800;background:linear-gradient(90deg,var(--purple-light),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.calc-total-btn{background:linear-gradient(135deg,var(--purple),var(--cyan));color:#fff;border:none;padding:.8rem 1.8rem;border-radius:50px;font-family:'Space Grotesk',sans-serif;font-weight:700;cursor:pointer;transition:transform .2s}
.calc-total-btn:hover{transform:scale(1.05)}

/* COMPARATIVO */
#comparativo{padding:6rem 6%;background:var(--bg2)}
.comp-header{text-align:center;margin-bottom:3rem}
.comp-table{max-width:900px;margin:0 auto;border:1px solid var(--border);border-radius:20px;overflow:hidden}
.comp-head{display:grid;grid-template-columns:2fr 1fr 1fr 1fr 1fr;background:rgba(124,58,237,.08);border-bottom:1px solid var(--border)}
.comp-head-cell{padding:1.2rem 1rem;font-family:'Syne',sans-serif;font-size:.9rem;text-align:center}
.comp-head-cell:first-child{text-align:left;color:var(--muted);font-size:.8rem}
.comp-head-cell.highlight{background:linear-gradient(135deg,rgba(124,58,237,.25),rgba(6,182,212,.1));color:var(--cyan)}
.comp-row{display:grid;grid-template-columns:2fr 1fr 1fr 1fr 1fr;border-bottom:1px solid var(--border)}
.comp-row:last-child{border-bottom:none}
.comp-row:hover{background:rgba(255,255,255,.02)}
.comp-cell{padding:.9rem 1rem;font-size:.85rem;text-align:center;color:var(--muted);display:flex;align-items:center;justify-content:center}
.comp-cell:first-child{text-align:left;justify-content:flex-start;color:var(--white);font-weight:500}
.comp-cell.highlight{background:rgba(124,58,237,.06)}
.check-yes{color:var(--green);font-size:1rem}
.check-no{color:rgba(255,255,255,.15);font-size:1rem}
.comp-price-row{display:grid;grid-template-columns:2fr 1fr 1fr 1fr 1fr;background:rgba(124,58,237,.08)}
.comp-price-cell{padding:1.2rem 1rem;text-align:center;font-weight:700;font-size:1rem}
.comp-price-cell:first-child{text-align:left;font-size:.85rem;font-weight:400;color:var(--muted)}
.comp-price-cell.highlight{color:var(--cyan)}

/* COMO FUNCIONA */
#como{padding:6rem 6%;display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
.steps{display:flex;flex-direction:column;gap:2rem}
.step{display:flex;gap:1.2rem;align-items:flex-start;opacity:0;transform:translateX(-30px);transition:all .6s ease}
.step.visible{opacity:1;transform:none}
.step-num{min-width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--purple),var(--cyan));display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:1rem}
.step-text h4{font-size:1rem;font-weight:600;margin-bottom:.3rem}
.step-text p{color:var(--muted);font-size:.9rem;line-height:1.6}
.mockup-wrap{background:var(--card);border:1px solid var(--border);border-radius:24px;padding:1.5rem;position:relative;opacity:0;transform:translateX(30px);transition:all .8s ease}
.mockup-wrap.visible{opacity:1;transform:none}
.mockup-bar{display:flex;gap:.4rem;margin-bottom:1rem}
.mockup-bar span{width:10px;height:10px;border-radius:50%}
.mockup-bar span:nth-child(1){background:#FF5F57}
.mockup-bar span:nth-child(2){background:#FEBC2E}
.mockup-bar span:nth-child(3){background:#28C840}
.mockup-screen{background:var(--bg);border-radius:12px;padding:1.5rem;min-height:220px}
.mockup-line{height:10px;border-radius:20px;margin-bottom:.8rem;animation:skeletonPulse 1.8s ease-in-out infinite}
.ml-1{background:linear-gradient(90deg,var(--purple),var(--cyan));width:60%}
.ml-2{background:var(--border);width:90%;animation-delay:.2s}
.ml-3{background:var(--border);width:75%;animation-delay:.4s}
.ml-4{background:var(--border);width:85%;animation-delay:.6s}
.ml-5{background:var(--border);width:50%;animation-delay:.8s}
.mockup-cta{height:34px;border-radius:20px;margin-top:1.2rem;width:45%;background:linear-gradient(90deg,var(--purple),var(--cyan));animation:glow 2s ease-in-out infinite alternate}

/* FAQ */
#faq{padding:6rem 6%;background:linear-gradient(180deg,var(--bg2),var(--bg))}
.faq-header{text-align:center;margin-bottom:3rem}
.faq-list{max-width:700px;margin:0 auto;display:flex;flex-direction:column;gap:.8rem}
.faq-item{background:var(--card);border:1px solid var(--border);border-radius:14px;overflow:hidden;opacity:0;transform:translateY(16px);transition:opacity .5s,transform .5s,border-color .3s}
.faq-item.visible{opacity:1;transform:none}
.faq-item.open{border-color:var(--purple)}
.faq-q{display:flex;align-items:center;justify-content:space-between;padding:1.2rem 1.4rem;cursor:pointer;font-weight:600;font-size:.95rem;gap:1rem}
.faq-icon{width:24px;height:24px;border-radius:50%;background:linear-gradient(135deg,var(--purple),var(--cyan));display:flex;align-items:center;justify-content:center;font-size:.8rem;flex-shrink:0;transition:transform .3s}
.faq-item.open .faq-icon{transform:rotate(45deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .4s ease,padding .3s}
.faq-a-inner{padding:0 1.4rem 1.2rem;color:var(--muted);font-size:.9rem;line-height:1.7}
.faq-item.open .faq-a{max-height:200px}

/* DEPOIMENTOS */
#depoimentos{padding:6rem 6%;text-align:center}
.dep-header{margin-bottom:3.5rem}
.dep-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem}
.dep-card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:2rem;text-align:left;opacity:0;transform:translateY(30px);transition:all .6s ease}
.dep-card.visible{opacity:1;transform:none}
.stars{color:#FBBF24;font-size:1rem;margin-bottom:1rem;letter-spacing:.1em}
.dep-text{color:var(--muted);font-size:.9rem;line-height:1.7;margin-bottom:1.2rem}
.dep-author{display:flex;align-items:center;gap:.8rem}
.dep-avatar{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--purple),var(--cyan));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem}
.dep-name{font-weight:600;font-size:.9rem}
.dep-role{color:var(--muted);font-size:.78rem}

/* CTA */
#cta{padding:6rem 6%;text-align:center;background:linear-gradient(180deg,var(--bg2),var(--bg))}
.cta-box{max-width:700px;margin:0 auto;background:linear-gradient(135deg,rgba(124,58,237,.2),rgba(6,182,212,.1));border:1px solid rgba(124,58,237,.4);border-radius:30px;padding:4rem 3rem;opacity:0;transform:scale(.95);transition:all .8s ease}
.cta-box.visible{opacity:1;transform:none}
.cta-box h2{font-family:'Syne',sans-serif;font-size:clamp(1.8rem,4vw,2.8rem);margin-bottom:1rem}
.cta-box p{color:var(--muted);margin-bottom:2rem;line-height:1.7}

footer{text-align:center;padding:2rem;color:var(--muted);font-size:.85rem;border-top:1px solid var(--border);position:relative;z-index:1}
footer a{color:var(--purple-light);text-decoration:none}

/* CHAT */
.chat-float{position:fixed;bottom:2rem;right:2rem;z-index:200}
.chat-btn{width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,var(--purple),var(--cyan));border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1.5rem;box-shadow:0 8px 32px rgba(124,58,237,.5);transition:transform .3s;animation:floatBounce 3s ease-in-out infinite;position:relative}
.chat-btn:hover{transform:scale(1.1)}
.chat-btn .chat-ring{position:absolute;inset:-4px;border-radius:50%;border:2px solid rgba(124,58,237,.4);animation:ringPulse 2s ease-out infinite}
.chat-notification{position:absolute;top:-4px;right:-4px;width:20px;height:20px;border-radius:50%;background:#EF4444;border:2px solid var(--bg);font-size:.65rem;font-weight:700;display:flex;align-items:center;justify-content:center;animation:notifPop .5s 2s cubic-bezier(.34,1.56,.64,1) both}
.chat-popup{position:absolute;bottom:76px;right:0;width:300px;background:#13131F;border:1px solid var(--border);border-radius:20px;overflow:hidden;box-shadow:0 24px 64px rgba(0,0,0,.6);transform:scale(0) translateY(20px);transform-origin:bottom right;transition:transform .35s cubic-bezier(.34,1.56,.64,1),opacity .3s;opacity:0;pointer-events:none}
